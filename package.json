{
  "name": "claude-code-teams-bot",
  "version": "0.5.0",
  "description": "Microsoft Teams bot that bridges to Claude Code",
  "keywords": [
    "microsoft-teams",
    "teams",
    "claude",
    "claude-code",
    "ai",
    "bot",
    "chatbot",
    "agent-sdk",
    "streaming"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Marvae/teams-claude-bot.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "teams-bot": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/run.sh",
    "scripts/package-manifest.mjs",
    ".claude/skills/",
    ".claude/hooks/",
    "manifest/",
    ".env.example"
  ],
  "scripts": {
    "dev": "concurrently -k -n bot,tunnel -c blue,green \"tsx watch src/index.ts\" \"node scripts/tunnel.mjs\"",
    "dev:local": "tsx watch src/index.ts",
    "build": "npm run build:bot && npm run build:cli",
    "build:bot": "npx esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --external:@anthropic-ai/claude-agent-sdk --external:@microsoft/teams.apps --external:@microsoft/teams.api --external:@microsoft/teams.cards --external:@microsoft/teams.dev --external:express --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "build:cli": "node scripts/build-cli.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:azure": "bash test/e2e-setup.sh",
    "package": "node scripts/package-manifest.mjs",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "@microsoft/teams.api": "^2.0.6",
    "@microsoft/teams.apps": "^2.0.6",
    "@microsoft/teams.cards": "^2.0.6",
    "commander": "^14.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "optionalDependencies": {
    "@azure/msal-node": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/teams.dev": "^2.0.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
